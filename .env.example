# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# POSTGRES (Supabase connection string)
POSTGRES_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# JWT
JWT_SECRET=super_secret_jwt_key_example

# STRIPE
STRIPE_SECRET_KEY=sk_test_placeholder
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_placeholder

# OTP / TWILIO (If not using Supabase built-in phone auth)
TWILIO_ACCOUNT_SID=AC_placeholder
TWILIO_AUTH_TOKEN=placeholder

# PUSH NOTIFICATIONS (Expo / FCM)
FCM_SERVER_KEY=placeholder
EXPO_ACCESS_TOKEN=placeholder
