PORT=5000
NODE_ENV=development

# Supabase — get these from your Supabase project's Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key

# Service role key bypasses RLS — required for admin-only routes
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: Stripe for payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: CORS origin for production
ALLOWED_ORIGIN=https://your-production-domain.com

# Optional: SMTP for order confirmation emails — if unset, emails are skipped (logged as a warning)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="FreshCart <no-reply@freshcart.example.com>"

# Required only for setup-db.js (direct Postgres connection for schema setup)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres
