{
  "name": "freshcart-monorepo",
  "private": true,
  "workspaces": [
    "freshcart-web",
    "freshcart-admin",
    "freshcart-mobile",
    "freshcart-backend",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:admin dev:backend",
    "dev:web": "npm --workspace freshcart-web run dev",
    "dev:admin": "npm --workspace freshcart-admin run dev",
    "dev:web-admin": "npm-run-all --parallel dev:web dev:admin",
    "dev:mobile": "npm --workspace freshcart-mobile start",
    "dev:backend": "npm --workspace freshcart-backend start"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "framer-motion": "^12.42.2"
  }
}
